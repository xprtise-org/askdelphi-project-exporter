<Window x:Class="AdPublisherUI.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Publishing" Height="150" Width="300" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Publishing... Please wait." HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="20"/>
    </Grid>
</Window>