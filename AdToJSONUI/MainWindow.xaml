<Window x:Class="AdPublisherUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export AskDelphi As JSON" Height="600" Width="850">
    <!-- Increased width for buttons -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <!-- New column for buttons -->
        </Grid.ColumnDefinitions>

        <!-- Auth File -->
        <Label Grid.Row="1" Grid.Column="0" Content="Auth File:"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtAuthFile" Margin="0,0,10,0"/>
        <Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" x:Name="btnBrowseAuthFile" Content="Browse" Click="btnBrowseAuthFile_Click" />

        <!-- Secret File -->
        <Label Grid.Row="3" Grid.Column="0" Content="Secret File:"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtSecretFile" Margin="0,0,10,0"/>

        <!-- Options File -->
        <Label Grid.Column="0" Content="Options File:"/>
        <TextBox Grid.Column="1" x:Name="txtOptionsFile" Margin="0,0,10,0"/>

        <!-- Tenant GUID -->
        <Label Grid.Row="5" Grid.Column="0" Content="Tenant GUID:"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtTenantGuid" Margin="0,0,10,0"/>

        <!-- ACL GUID -->
        <Label Grid.Row="7" Grid.Column="0" Content="ACL GUID:"/>
        <TextBox Grid.Row="7" Grid.Column="1" x:Name="txtAclGuid" Margin="0,0,10,0"/>

        <!-- Workflow Stage -->
        <Label Grid.Row="4" Grid.Column="0" Content="Workflow Stage:"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtWorkflowStage" Margin="0,0,10,0"/>

        <!-- Project GUID -->
        <Label Grid.Row="6" Grid.Column="0" Content="Project GUID:"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtProjectGuid" Margin="0,0,10,0"/>

        <!-- API URL -->
        <Label Grid.Row="8" Grid.Column="0" Content="API URL:"/>
        <TextBox Grid.Row="8" Grid.Column="1" x:Name="txtApiUrl" Margin="0,0,10,0"/>

        <!-- Out Folder -->
        <Label Grid.Row="9" Grid.Column="0" Content="Out Folder:"/>
        <TextBox Grid.Row="9" Grid.Column="1" x:Name="txtOutFolder" Margin="0,0,10,0"/>
        <Button Grid.Row="9" Grid.Column="2" Grid.ColumnSpan="2" x:Name="btnBrowseOutFolder" Content="Browse" Click="btnBrowseOutFolder_Click" />

        <!-- Session Code -->
        <Label Grid.Row="2" Grid.Column="0" Content="Session Code:"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSessionCode" Margin="0,0,10,0"/>
        <Button Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" x:Name="btnAuthenticateNow" Content="Authenticate Now" Click="btnAuthenticateNow_Click"/>

        <!-- Base URL -->
        <Label Grid.Row="10" Grid.Column="0" Content="Base URL:"/>
        <TextBox Grid.Row="10" Grid.Column="1" x:Name="txtBaseUrl" Margin="0,0,10,0"/>

        <!-- Out Container URI -->
        <Label Grid.Row="11" Grid.Column="0" Content="Out Container URI:"/>
        <TextBox Grid.Row="11" Grid.Column="1" x:Name="txtOutContainerUri" IsEnabled="False" Margin="0,0,10,0"/>

        <!-- Content Set -->
        <Label Grid.Row="12" Grid.Column="0" Content="Content Set:"/>
        <ListBox Grid.Row="12" Grid.Column="1" x:Name="lstContentSet" Margin="0,0,10,0" MouseDoubleClick="lstContentSet_MouseDoubleClick"/>
        <StackPanel Grid.Row="12" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Vertical">
            <Button x:Name="btnAddRule" Content="Add Rule" Click="btnAddRule_Click"/>
            <Button x:Name="btnRemoveRule" Content="Remove Rule" Click="btnRemoveRule_Click"/>
        </StackPanel>

        <!-- Load/Save Buttons -->
        <StackPanel Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnLoad" Content="Load" Click="btnLoad_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnSave" Content="Save" Click="btnSave_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnRunNow" Content="Run Now" Click="btnRunNow_Click"/>
        </StackPanel>
    </Grid>
</Window>